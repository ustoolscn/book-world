# Backend server address
ADDR=:8080

# PostgreSQL connection string
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=disable
DATABASE_URL=postgres://postgres:postgres@localhost:5432/book_world?sslmode=disable

# Used only when frontend does not send a selected model
DEFAULT_MODEL=gpt-4o-mini

# Context builder character budgets
CONTEXT_CHAR_BUDGET=48000
REPLY_CHAR_RESERVE=6000

# Dev CORS origin for Vite frontend
FRONTEND_ORIGIN=http://localhost:5173
